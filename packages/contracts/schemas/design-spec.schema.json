{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://furniture-platform.org/schemas/design-spec.schema.json",
  "title": "DesignSpec",
  "description": "Canonical user design intent. LLMs may only produce validated patches of this document; all geometry is derived from it deterministically by the kernel.",
  "type": "object",
  "required": ["specVersion", "projectId", "revision", "productType", "parameters"],
  "additionalProperties": false,
  "properties": {
    "specVersion": { "const": 1 },
    "projectId": { "type": "string", "minLength": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "manufacturerId": { "type": "string" },
    "productType": { "type": "string", "enum": ["wardrobe", "bed", "vanity", "kommode", "table"] },
    "parameters": {
      "description": "Template-specific parameters, validated against the product template's own parameter schema (mm for lengths). Values may be nested (e.g. wardrobe `sections` array).",
      "type": "object",
      "additionalProperties": { "type": ["number", "string", "boolean", "integer", "object", "array"] }
    },
    "room": {
      "description": "Customer room context: typed dimensions and an optional uploaded photo key. Drives room-aware validation and the scale room shell in print packs.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "widthMm": { "type": "number", "exclusiveMinimum": 0 },
        "depthMm": { "type": "number", "exclusiveMinimum": 0 },
        "heightMm": { "type": "number", "exclusiveMinimum": 0 },
        "photoKey": { "type": "string" },
        "notes": { "type": "string", "maxLength": 2000 }
      }
    },
    "finish": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "materialId": { "type": "string" },
        "colorId": { "type": "string" }
      }
    },
    "origin": { "type": "string", "enum": ["llm", "form", "fastpath"] },
    "notes": { "type": "string", "maxLength": 2000 }
  }
}

# Copy to .env on the server. Never commit .env.
DOMAIN=furniture.example.org
DATABASE_URL=postgres://furniture:changeme@postgres:5432/furniture
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=furniture
S3_SECRET_KEY=changeme
S3_BUCKET=artifacts

# Model routing — provider:model. Providers: openai-compatible endpoints
# (ollama/vllm/llamacpp/openrouter/...) or anthropic. Fully local is fine.
MODEL_SMALL=ollama:qwen3:8b
MODEL_LARGE=ollama:qwen3:32b
OPENAI_COMPAT_BASE_URL=http://ollama:11434/v1
OPENAI_COMPAT_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=

DAILY_TOKEN_BUDGET=2000000
SESSION_TOKEN_BUDGET=200000
